# ============================================================================
# Lawyerly — environment variables (example)
# Copy to `.env` and fill in real values. NEVER commit the real `.env`.
# ============================================================================

# ---- Runtime ----------------------------------------------------------------
NODE_ENV=development
CORE_API_PORT=4000
# The single official frontend origin allowed by CORS (§11).
WEB_ORIGIN=http://localhost:3000
ADMIN_WEB_ORIGIN=http://localhost:3100

# ---- Database (PostgreSQL) --------------------------------------------------
# Used by Prisma. Matches the docker-compose `db` service defaults.
POSTGRES_USER=lawyerly
POSTGRES_PASSWORD=lawyerly_dev_password
POSTGRES_DB=lawyerly
POSTGRES_HOST=localhost
# Host port for the dev container (mapped to container 5432). Uses 5433 to avoid
# clashing with a locally-installed PostgreSQL on 5432.
POSTGRES_PORT=5433
DATABASE_URL=postgresql://lawyerly:lawyerly_dev_password@localhost:5433/lawyerly?schema=public

# ---- Auth / JWT (§11) -------------------------------------------------------
# Access tokens: 15-min expiry. Refresh tokens: 30-day, rotated on each use.
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---- Field encryption (§11) -------------------------------------------------
# App-level AES-256-GCM for CNIC + TOTP secrets. Must be 32 bytes, base64-encoded.
# Generate: `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`
FIELD_ENCRYPTION_KEY=change-me-32-byte-base64-key

# ---- Object storage (S3-compatible / MinIO) (§11) ---------------------------
# Documents + profile photos. Encrypted at rest, served via 1-hour pre-signed URLs.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=lawyerly-documents
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_TTL_SECONDS=3600

# ---- Chatbot LLM (direct chat-completions API — NO RAG) (§9.1) --------------
# Google Gemini (free tier), model gemini-2.5-flash. Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key-here

# ---- AI service (OCR + NLP microservice) (§9.2) -----------------------------
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=change-me-internal-service-key

# ---- Transactional email (OTP, verification, notifications) (§13) -----------
EMAIL_PROVIDER=smtp
EMAIL_FROM="Lawyerly <no-reply@lawyerly.pk>"
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

# ---- Security knobs (§11) ---------------------------------------------------
RATE_LIMIT_PUBLIC_PER_MIN=60
RATE_LIMIT_AUTH_PER_MIN=300
SESSION_INACTIVITY_TIMEOUT_MIN=30
MAX_CONCURRENT_SESSIONS=3
# Google reCAPTCHA v2 (shown after 3 failed logins, §7.3)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ---- Third-party integrity checks -------------------------------------------
# HaveIBeenPwned range API is keyless for k-anonymity password checks (§7.4).
HIBP_ENABLED=true
