# ============================================================================
# core-api — deployed on Koyeb. Copy to `.env` for local dev; in production
# set these as Koyeb service env vars. NEVER commit the real `.env`.
# ============================================================================

# ---- Runtime ----------------------------------------------------------------
NODE_ENV=development
# Koyeb assigns PORT dynamically in production; CORE_API_PORT is the local fallback.
CORE_API_PORT=4000
WEB_ORIGIN=http://localhost:3000
ADMIN_WEB_ORIGIN=http://localhost:3100
# Comma-separated. In production set to the exact Vercel URLs for web + admin-web.
CORS_ORIGIN=http://localhost:3000,http://localhost:3100

# ---- Database (Neon Postgres) ------------------------------------------------
# Neon provides two connection string variants:
#
#   DATABASE_URL  — pooled connection via PgBouncer (use for all runtime queries).
#                   Format: postgres://user:pass@<project>.neon.tech/dbname?sslmode=require
#                   In Neon dashboard: Connection Details → "Pooled connection" toggle ON.
#
#   DIRECT_URL    — unpooled direct connection (required for Prisma migrations).
#                   PgBouncer in transaction mode breaks the prepared statements
#                   Prisma's migration engine relies on; migrations MUST use the
#                   direct URL. Format is identical but without pgbouncer in the host.
#                   In Neon dashboard: Connection Details → "Pooled connection" toggle OFF.
#
# For local dev both can point to the same local Postgres instance.
DATABASE_URL=postgresql://lawyerly:lawyerly_dev_password@localhost:5433/lawyerly?schema=public
DIRECT_URL=postgresql://lawyerly:lawyerly_dev_password@localhost:5433/lawyerly?schema=public

# ---- Auth / JWT (§11) -------------------------------------------------------
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---- Field encryption (§11) -------------------------------------------------
FIELD_ENCRYPTION_KEY=change-me-32-byte-base64-key

# ---- Object storage (Cloudflare R2, S3-compatible) (§11) --------------------
# R2 endpoint format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=lawyerly-documents
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_TTL_SECONDS=3600

# ---- Chatbot LLM (direct chat-completions API — NO RAG) (§9.1) --------------
GEMINI_API_KEY=your-key-here

# ---- AI service (ai-service on Render) (§9.2) -------------------------------
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=change-me-internal-service-key

# ---- Transactional email (§13) ----------------------------------------------
EMAIL_PROVIDER=smtp
EMAIL_FROM="Lawyerly <no-reply@lawyerly.pk>"
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

# ---- Security knobs (§11) ---------------------------------------------------
RATE_LIMIT_PUBLIC_PER_MIN=60
RATE_LIMIT_AUTH_PER_MIN=300
SESSION_INACTIVITY_TIMEOUT_MIN=30
MAX_CONCURRENT_SESSIONS=3
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
ADMIN_SESSION_TIMEOUT_MIN=30
ADMIN_ALERT_EMAIL=superadmin@lawyerly.pk

# ---- Third-party integrity checks -------------------------------------------
HIBP_ENABLED=true

# ---- Consultation auto-expiry sweep (ms) ------------------------------------
CONSULTATION_EXPIRY_INTERVAL_MS=300000
